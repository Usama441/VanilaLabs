<script>
(function() {
  const projects = <%= @projects.to_json.html_safe %>;

  function artwork(kind){
   const defs='<defs><linearGradient id="g" x1="0" x2="1" y1="0" y2="1"><stop stop-color="#f5e6c8" stop-opacity=".26"/><stop offset="1" stop-color="#d4a853" stop-opacity=".08"/></linearGradient><radialGradient id="r" cx="50%" cy="30%" r="70%"><stop stop-color="#d4a853" stop-opacity=".26"/><stop offset="1" stop-color="#050505" stop-opacity="0"/></radialGradient></defs>';
   const bg=`<svg viewBox="0 0 700 420" preserveAspectRatio="none">${defs}<rect width="700" height="420" fill="#090909"/><circle cx="520" cy="80" r="210" fill="url(#r)"/><path d="M0 350 C150 260 240 390 390 270 S610 180 700 245" fill="none" stroke="#d4a853" stroke-opacity=".28" stroke-width="2"/>`;
   const map={analytics:'<rect x="70" y="90" width="560" height="250" rx="28" fill="url(#g)" stroke="#f5e6c8" stroke-opacity=".16"/><path d="M120 285 L210 210 L300 245 L410 150 L570 190" fill="none" stroke="#f5e6c8" stroke-width="5" stroke-linecap="round"/><circle cx="410" cy="150" r="14" fill="#d4a853"/>',commerce:'<rect x="95" y="80" width="180" height="250" rx="26" fill="url(#g)"/><rect x="315" y="120" width="290" height="170" rx="28" fill="url(#g)"/><circle cx="185" cy="180" r="50" fill="#d4a853" fill-opacity=".22"/><path d="M370 180h170M370 220h110" stroke="#f5e6c8" stroke-opacity=".45" stroke-width="8" stroke-linecap="round"/>',infra:'<path d="M140 120h420v70H140zM140 220h420v70H140z" fill="url(#g)" stroke="#f5e6c8" stroke-opacity=".14"/><circle cx="190" cy="155" r="10" fill="#d4a853"/><circle cx="190" cy="255" r="10" fill="#d4a853"/><path d="M250 155h250M250 255h210" stroke="#f5e6c8" stroke-opacity=".4" stroke-width="7" stroke-linecap="round"/>',crm:'<rect x="90" y="75" width="520" height="270" rx="30" fill="url(#g)"/><rect x="130" y="125" width="110" height="160" rx="18" fill="#050505" fill-opacity=".45"/><rect x="270" y="125" width="110" height="160" rx="18" fill="#050505" fill-opacity=".35"/><rect x="410" y="125" width="110" height="160" rx="18" fill="#050505" fill-opacity=".25"/>',brand:'<circle cx="350" cy="205" r="115" fill="url(#g)"/><path d="M245 205h210M350 100v210" stroke="#f5e6c8" stroke-opacity=".38" stroke-width="5"/><text x="350" y="220" text-anchor="middle" font-size="54" fill="#f5e6c8" font-family="Syne" font-weight="800">VL</text>',api:'<circle cx="200" cy="210" r="58" fill="url(#g)"/><circle cx="500" cy="140" r="50" fill="url(#g)"/><circle cx="500" cy="285" r="50" fill="url(#g)"/><path d="M255 200 C350 160 390 145 450 145M255 220 C350 270 390 285 450 285" stroke="#f5e6c8" stroke-opacity=".38" stroke-width="5" fill="none" stroke-linecap="round"/>'};
   return bg+(map[kind]||map.brand)+'</svg>';
  }

  function escapeHtml(str){return String(str).replace(/[&<>"']/g,m=>({'&':'&','<':'<','>':'>','"':'"',"'":'&#39;'}[m]))}

  function initHome() {
    const grid = document.getElementById('workGrid');
    if (!grid) return;

    function render(filter='all'){
     grid.innerHTML=projects.filter(p=>filter==='all'||p.cat===filter).map((p,i)=>`<article class="work-card reveal visible" tabindex="0" data-id="${p.id}" data-hover="${escapeHtml(p.desc)}"><div class="thumb">${artwork(p.art)}</div><div class="work-info"><div class="tag">${p.tag}</div><h3>${p.title}</h3><div class="open-row"><span>Hover to preview</span><span>→</span></div></div><div class="hover-detail"><h4>${p.title}</h4><span class="typewriter"></span><div class="hover-points">${p.points.map(x=>`<span>${x}</span>`).join('')}</div><a href="/work/${p.id}" class="hover-click">Click for full case →</a></div></article>`).join('');
     document.querySelectorAll('.work-card').forEach(card=>{
       card.addEventListener('click',() => {
         window.location.href = `/work/${card.dataset.id}`;
       });
       card.addEventListener('mouseenter',()=>typeCard(card));
       card.addEventListener('focus',()=>typeCard(card));
       card.addEventListener('mouseleave',()=>resetType(card));
       card.addEventListener('blur',()=>resetType(card));
     });
    }

    function typeCard(card){
     if(!box)return;
     clearInterval(card._typeTimer);
     const text=card.dataset.hover || '';
     let i=0;
     box.innerHTML='<span class="caret"></span>';
     card._typeTimer=setInterval(()=>{
       i++;
       box.innerHTML=escapeHtml(text.slice(0,i))+'<span class="caret"></span>';
       if(i>=text.length)clearInterval(card._typeTimer);
     },16);
    }

    function resetType(card){
     clearInterval(card._typeTimer);
     const box=card.querySelector('.typewriter');
     if(box)box.innerHTML='';
    }

    render('all');

    document.querySelectorAll('.filter').forEach(btn=>btn.addEventListener('click',()=>{
      document.querySelectorAll('.filter').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      render(btn.dataset.filter);
    }));

    const modal=document.getElementById('modal');
    function openProject(id){
      const p=projects.find(x=>x.id===id);
      if(!p)return;
      document.getElementById('modalHero').innerHTML=artwork(p.art);
      document.getElementById('modalTag').textContent=p.tag;
      document.getElementById('modalTitle').textContent=p.title;
      document.getElementById('modalDesc').textContent=p.desc;
      document.getElementById('modalType').textContent=p.type;
      document.getElementById('modalDelivery').textContent=p.delivery;
      document.getElementById('modalList').innerHTML=p.points.map(x=>`<li>${x}</li>`).join('');
      modal.classList.add('show');
      modal.setAttribute('aria-hidden','false');
      document.body.style.overflow='hidden';
    }

    function closeProject(){
      modal.classList.remove('show');
      modal.setAttribute('aria-hidden','true');
      document.body.style.overflow='';
    }

    document.getElementById('closeModal')?.addEventListener('click',closeProject);
    modal?.addEventListener('click',e=>{if(e.target===modal)closeProject()});
    document.addEventListener('keydown',e=>{if(e.key==='Escape')closeProject()});

    const hero3d=document.getElementById('hero3d');
    document.addEventListener('mousemove',e=>{
      if(!hero3d || innerWidth<900)return;
      const x=(e.clientX/innerWidth-.5)*10;
      const y=(e.clientY/innerHeight-.5)*-10;
      hero3d.style.transform=`rotateY(${x}deg) rotateX(${y}deg)`
    });
  }

  document.addEventListener('turbo:load', initHome);
})();
</script>
