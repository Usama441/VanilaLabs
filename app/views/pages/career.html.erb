<%= render "shared/header" %>

<div class="noise"></div>
<div class="cursor-glow" id="glow"></div>

<main>
  <section class="section internal-hero">
    <div class="reveal">
      <div class="eyebrow">Work with us</div>
      <h1>Help us build the <span class="gold">future of immersive tech.</span></h1>
      <p class="lead" style="margin-top: 26px">We are always looking for obsessed designers, developers, and system architects who want to push the boundaries of the digital medium.</p>
    </div>

    <div class="job-grid reveal">
      <div class="job-card">
        <div class="job-info">
          <h3>Full-Stack Engineer</h3>
          <div class="job-meta"><span>Remote / Hybrid</span><span>Full-Time</span><span>Rails + Hotwire</span></div>
        </div>
        <a href="mailto:careers@vanillalabs.io" class="btn">Apply Now →</a>
      </div>

      <div class="job-card">
        <div class="job-info">
          <h3>Visual Designer</h3>
          <div class="job-meta"><span>Remote</span><span>Contract</span><span>3D + UI/UX</span></div>
        </div>
        <a href="mailto:careers@vanillalabs.io" class="btn">Apply Now →</a>
      </div>

      <div class="job-card">
        <div class="job-info">
          <h3>DevOps Architect</h3>
          <div class="job-meta"><span>Hybrid (UK/EU)</span><span>Full-Time</span><span>Infrastructure</span></div>
        </div>
        <a href="mailto:careers@vanillalabs.io" class="btn">Apply Now →</a>
      </div>
    </div>

    <div class="content-block reveal">
      <h2>Don't see your role?</h2>
      <p class="lead" style="margin-top: 20px">We are always open to hearing from exceptional talent. Send us your portfolio or GitHub and tell us why you'd be a great fit for the lab.</p>
      <div class="btn-row">
        <a href="mailto:careers@vanillalabs.io" class="btn primary">Send open application</a>
      </div>
    </div>
  </section>
</main>

<%= render "shared/footer" %>
